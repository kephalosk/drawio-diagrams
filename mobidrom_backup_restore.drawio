        <mxCell id="A18jpzIbLcYZRwKmN8_x-52" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="export const useHandleSicherungAllServices = (&lt;br&gt;&amp;nbsp; &amp;nbsp; startSicherungForTarget: (service?: SUWServiceConfig) =&amp;gt; Promise&amp;lt;void&amp;gt;,&lt;br&gt;&amp;nbsp; &amp;nbsp; setIsRunningGlobalSicherung: Dispatch&amp;lt;SetStateAction&amp;lt;boolean&amp;gt;&amp;gt;,&lt;br&gt;) =&amp;gt; {&lt;br&gt;&amp;nbsp; &amp;nbsp; const { setAlert } = useContext(MainContext);&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; return useCallback(async () =&amp;gt; {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; setIsRunningGlobalSicherung(true);&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; try {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; await startSicherungForTarget();&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; } catch (error) {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; setAlert(&#39;error&#39;, &#39;Fehler&#39;, `Bei der Sicherung aller Dienste ist folgender Fehler aufgetreten: ${error}`, true);&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; } finally {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; setIsRunningGlobalSicherung(false);&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;br&gt;&amp;nbsp; &amp;nbsp; }, [setAlert, setIsRunningGlobalSicherung, startSicherungForTarget]);&lt;br&gt;};" vertex="1">
