        <mxCell id="A18jpzIbLcYZRwKmN8_x-67" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="export const startSicherungProcess = async (&lt;br&gt;&amp;nbsp; &amp;nbsp; keycloak: Keycloak,&lt;br&gt;&amp;nbsp; &amp;nbsp; serviceName?: string,&lt;br&gt;): Promise&amp;lt;{ processId: string; reusedRunningProcess: boolean }&amp;gt; =&amp;gt; {&lt;br&gt;&amp;nbsp; &amp;nbsp; const response = await fetch(buildUrl(&#39;/backup/start&#39;, { serviceName }), {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; headers: createAuthorizedHeaders(keycloak),&lt;br&gt;&amp;nbsp; &amp;nbsp; });&lt;br&gt;&amp;nbsp; &amp;nbsp; const message = await readResponseText(response);&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; if (!response.ok &amp;amp;&amp;amp; response.status !== 409) {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; throw new Error(message || &#39;Sicherung konnte nicht gestartet werden.&#39;);&lt;br&gt;&amp;nbsp; &amp;nbsp; }&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; return {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; processId: extractProcessId(message),&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; reusedRunningProcess: response.status === 409,&lt;br&gt;&amp;nbsp; &amp;nbsp; };&lt;br&gt;};" vertex="1">
