        <mxCell id="A18jpzIbLcYZRwKmN8_x-59" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="export const useStartSicherungForTarget = ({&lt;br&gt;&amp;nbsp; &amp;nbsp; setSicherungEvents,&lt;br&gt;&amp;nbsp; &amp;nbsp; setSystemSicherungEvent,&lt;br&gt;}: {&lt;br&gt;&amp;nbsp; &amp;nbsp; setSicherungEvents: Dispatch&amp;lt;SetStateAction&amp;lt;Record&amp;lt;string, SUWEvent | undefined&amp;gt;&amp;gt;&amp;gt;;&lt;br&gt;&amp;nbsp; &amp;nbsp; setSystemSicherungEvent: Dispatch&amp;lt;SetStateAction&amp;lt;SUWEvent | undefined&amp;gt;&amp;gt;;&lt;br&gt;}) =&amp;gt; {&lt;br&gt;&amp;nbsp; &amp;nbsp; const { keycloak } = useKeycloak();&lt;br&gt;&amp;nbsp; &amp;nbsp; const { setAlert } = useContext(MainContext);&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; return useCallback(&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; async (service?: SUWServiceConfig) =&amp;gt; {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (!keycloak) {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; const serviceName = service?.key;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; const targetName = service?.name ?? &#39;Gesamtsystem&#39;;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; const { processId, reusedRunningProcess } = await startSicherungProcess(&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; keycloak,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; serviceName &amp;amp;&amp;amp; serviceName !== ALLE_SERVICES_KEY ? serviceName : undefined,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; );&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; const pendingEvent = createPendingEvent(processId, &#39;sicherung&#39;, targetName);&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; if (service) {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; setSicherungEvents((currentState) =&amp;gt; ({&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ...currentState,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; [service.key]: pendingEvent,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }));&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; } else {&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; setSystemSicherungEvent(pendingEvent);&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;br&gt;&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; setAlert(&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; reusedRunningProcess ? &#39;info&#39; : &#39;success&#39;,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; reusedRunningProcess ? &#39;Information&#39; : &#39;Erfolg&#39;,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; reusedRunningProcess&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; ? `Für &quot;${targetName}&quot; läuft bereits ein Sicherungsprozess. Die vorhandene Prozess-ID wurde übernommen.`&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; : `Die Sicherung für &quot;${targetName}&quot; wurde erfolgreich gestartet.`,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; true,&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; );&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; },&lt;br&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; [keycloak, setAlert, setSicherungEvents, setSystemSicherungEvent],&lt;br&gt;&amp;nbsp; &amp;nbsp; );&lt;br&gt;};" vertex="1">
