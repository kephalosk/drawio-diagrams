        </mxCell>
        <mxCell id="28_t6dSwFopjIzpQFVjB-97" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Identität" vertex="1">
