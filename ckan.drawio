        <mxCell id="J_fL0BtIRvY3yV5KD3YF-46" value="&lt;div&gt;Aufgabe:&lt;/div&gt;&lt;div&gt;Verarbeitet hochgeladene Dateien wie CSV/Excel&lt;/div&gt;&lt;div&gt;Füllt diese automatisch in den Datastore (PostgreSQL-Tabelle)&lt;/div&gt;&lt;div&gt;Wenn du CSV-Dateien als Ressourcen hochlädst, ist der Datapusher verantwortlich, dass sie als Tabellen in CKAN erscheinen.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;labelPosition=center;verticalLabelPosition=middle;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1440" y="2270" width="370" height="160" as="geometry" />
        </mxCell>
        <mxCell id="J_fL0BtIRvY3yV5KD3YF-47" value="&lt;div&gt;db:&lt;/div&gt;&lt;div&gt;&amp;nbsp; build:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; context: postgresql/&lt;/div&gt;&lt;div&gt;&amp;nbsp; networks:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; - dbnet&lt;/div&gt;&lt;div&gt;&amp;nbsp; environment:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - POSTGRES_USER&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - POSTGRES_PASSWORD&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; - POSTGRES_DB&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ...&lt;/div&gt;&lt;div&gt;&amp;nbsp; volumes:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; - pg_data:/var/lib/postgresql/data&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;labelPosition=center;verticalLabelPosition=middle;verticalAlign=top;" vertex="1" parent="1">
