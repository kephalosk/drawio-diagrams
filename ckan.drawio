        <mxCell id="J_fL0BtIRvY3yV5KD3YF-37" value="&lt;div&gt;CKAN&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=center;labelPosition=center;verticalLabelPosition=middle;verticalAlign=top;fontSize=24;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="2190" y="1680" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="J_fL0BtIRvY3yV5KD3YF-39" value="&lt;div&gt;Aufgabe:&lt;/div&gt;&lt;div&gt;Das Herz der Anwendung&lt;/div&gt;&lt;div&gt;Startet CKAN-Python-App&lt;/div&gt;&lt;div&gt;Nutzt Datenbank, Solr, Redis, Datapusher&lt;/div&gt;&lt;div&gt;Wichtige Elemente:&lt;/div&gt;&lt;div&gt;env_file: .env&lt;/div&gt;&lt;div&gt;Alle CKAN-Einstellungen werden dort eingelesen.&lt;/div&gt;&lt;div&gt;depends_on&lt;/div&gt;&lt;div&gt;CKAN startet erst, wenn:&lt;/div&gt;&lt;div&gt;PostgreSQL bereit ist&lt;/div&gt;&lt;div&gt;Solr bereit ist&lt;/div&gt;&lt;div&gt;Redis bereit ist&lt;/div&gt;&lt;div&gt;Healthcheck&lt;/div&gt;&lt;div&gt;CKAN gilt als „gesund“, wenn:&lt;/div&gt;&lt;div&gt;/api/action/status_show&lt;/div&gt;&lt;div&gt;erreichbar ist.&lt;/div&gt;&lt;div&gt;Volumes&lt;/div&gt;&lt;div&gt;Damit CKAN stabil bleibt und nicht immer neu gebaut werden muss.&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;labelPosition=center;verticalLabelPosition=middle;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="2280" y="1760" width="370" height="400" as="geometry" />
        </mxCell>
        <mxCell id="J_fL0BtIRvY3yV5KD3YF-42" value="&lt;div&gt;datapusher:&lt;/div&gt;&lt;div&gt;&amp;nbsp; networks:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; - ckannet&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; - dbnet&lt;/div&gt;&lt;div&gt;&amp;nbsp; image: ckan/ckan-base-datapusher:${DATAPUSHER_VERSION}&lt;/div&gt;&lt;div&gt;&amp;nbsp; restart: unless-stopped&lt;/div&gt;&lt;div&gt;&amp;nbsp; healthcheck:&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; test: [&quot;CMD&quot;, &quot;wget&quot;, &quot;-qO&quot;, &quot;/dev/null&quot;, &quot;http://localhost:8800&quot;]&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;labelPosition=center;verticalLabelPosition=middle;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1030" y="2270" width="370" height="190" as="geometry" />
        </mxCell>
        <mxCell id="J_fL0BtIRvY3yV5KD3YF-43" value="" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="J_fL0BtIRvY3yV5KD3YF-45" target="J_fL0BtIRvY3yV5KD3YF-42">
