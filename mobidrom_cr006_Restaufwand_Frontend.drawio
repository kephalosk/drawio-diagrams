        <mxCell id="6I-_ciG7kh0R2IqJ13tL-677" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=none;fontSize=18;fontStyle=1;align=left;" value="Warum noch? Devs nicht zu Laufburschen/Laufmädchen machen über 3 Ecken" vertex="1">
