        <mxCell id="6I-_ciG7kh0R2IqJ13tL-671" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=none;fontSize=18;fontStyle=1;align=left;" value="D.h. WENN eine Story Backend, DevOps und Frontend umfasst, DANN MUSS es von Anfang bis Ende für jeden technischen Bereich einen eigenen zuständigen Story-Owner geben " vertex="1">
