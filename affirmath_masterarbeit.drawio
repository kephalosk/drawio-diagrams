          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-41" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="&lt;div&gt;Zu jedem Affirmationsblock werden 12 Affirmationen gebildet, z.B. in Bezug auf Selbstwert:&lt;/div&gt;" vertex="1">
          <mxGeometry height="40" width="520" x="1470" y="930" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-43" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="1. Ich bin wichtig; ich bin dankbar für alles gute in meinem Leben.&lt;br&gt;2. Ich bin geliebt; das bin ich; alles andere ist egal.&lt;br&gt;3. Ich bin voller Freude; ich liebe meine Affirmationen mehr als alles andere.&lt;br&gt;4. Ich bin gut so wie ich bin; ich habe nur das beste verdient.&lt;br&gt;5. Ich bin ruhig wie gelassen; ich bin 1.&lt;br&gt;6. Ich lasse alle negativen Gedanken verblassen.&lt;br&gt;7. Ich sehe in Allem das Positive Gute; ich bin liebenswert.&lt;br&gt;8. Alles ist ein wichtiger Baustein für mein Leben.&lt;br&gt;9. Es geschieht alles so wie es vorherbestimmt ist.&lt;br&gt;10. Ich akzeptiere alles, was ich nicht ändern kann.&lt;br&gt;11. Alle Probleme sind bereits gelöst.&lt;br&gt;12. Ich bin vollkommen gesund, geheilt; ich bin stark; ich bin gut." vertex="1">
          <mxGeometry height="285" width="300" x="2040" y="805" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-48" edge="1" parent="1" source="LeoVObrxh5ZpNmHJ5fCl-45" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="LeoVObrxh5ZpNmHJ5fCl-47" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-45" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="4. Durchführung von Affirmationen" vertex="1">
          <mxGeometry height="40" width="120" x="1310" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-52" edge="1" parent="1" source="LeoVObrxh5ZpNmHJ5fCl-47" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="LeoVObrxh5ZpNmHJ5fCl-51" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-47" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Ein Affirmationsblock wird 12 mal wiederholt. Dabei werden die Affirmationen ausgesprochen und gleichzeitig wird mit den Fingerspitzen auf bestimmte Körperstellen geklopft, die sich mit jeder Affirmation durchgehend abwechseln." vertex="1">
          <mxGeometry height="80" width="520" x="1470" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-49" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Das ergibt bei 5 Lebensbereichen zu je 5 Affirmationsblöcken zu je 12 Affirmationen insgesamt 300 unterschiedliche Affirmationen die ausformuliert werden. Eine Affirmation ist rund 9 Worte lang. Das ergibt etwa 2700 Wörter." vertex="1">
          <mxGeometry height="50" width="520" x="1470" y="990" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-54" edge="1" parent="1" source="LeoVObrxh5ZpNmHJ5fCl-51" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="LeoVObrxh5ZpNmHJ5fCl-53" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-51" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Der Vorgang nimmt rund 5 Minuten in Anspruch, bzw. circa zwei bis drei Sekunden je Affirmation." vertex="1">
          <mxGeometry height="40" width="520" x="1470" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-53" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Nach dem Durchlauf erfolgt eine Abklingzeit von mindestens ein bis zwei Minuten. Danach kann mit dem nächsten Affirmationsblock fortgefahren werden." vertex="1">
          <mxGeometry height="40" width="520" x="1470" y="1280" as="geometry" />
        </mxCell>
