        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-42" edge="1" parent="1" source="LeoVObrxh5ZpNmHJ5fCl-39" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="LeoVObrxh5ZpNmHJ5fCl-41" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LeoVObrxh5ZpNmHJ5fCl-39" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Zu jedem Lebensbereich werden 5 Affirmationsblöcke gebildet, z.B. im Bezug auf Selbstbestimmung: Selbstwert, Talent, Kraft, Heilung, Selbstsicherheit" vertex="1">
          <mxGeometry height="40" width="520" x="1470" y="850" as="geometry" />
        </mxCell>
